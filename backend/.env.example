# ─────────────────────────────────────────────────────────────
# VisitPro – Backend Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
PROJECT_NAME=VisitPro

# ── Security (CHANGE THESE IN PRODUCTION!) ───────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_change_me_min_64_chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# ── CORS & Cookies ────────────────────────────────────────────
# Development:
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
COOKIE_SECURE=False
# Production (override with):
# BACKEND_CORS_ORIGINS=https://visitpro.de
# COOKIE_SECURE=True

# ── PostgreSQL ────────────────────────────────────────────────
# Development (local pgAdmin):
POSTGRES_SERVER=localhost
POSTGRES_USER=visitpro_user
POSTGRES_PASSWORD=your_dev_db_password
POSTGRES_DB=visitpro
# Production (Docker service name = "postgres"):
# POSTGRES_SERVER=postgres
# DATABASE_URL is auto-built from the above. Optionally set explicitly:
# DATABASE_URL=postgresql+asyncpg://visitpro_user:your_password@postgres:5432/visitpro

# ── Redis ─────────────────────────────────────────────────────
# Development – use Upstash (cloud) or local Redis:
# Option A – Upstash:
# REDIS_URL=rediss://default:your_token@your-host.upstash.io:6379
# Option B – Local Redis:
REDIS_HOST=localhost
REDIS_PORT=6379
# Production (Docker service name = "redis"):
# REDIS_HOST=redis
# REDIS_PORT=6379

# ── Email (Brevo) ─────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
SENDER_EMAIL=hello@visitpro.de
SENDER_NAME=VisitPro

# ── App URL (used in email verification links) ────────────────
# Development:
APP_BASE_URL=http://localhost:5173
# Production:
# APP_BASE_URL=https://visitpro.de

# ── GoCardless ───────────────────────────────────────────────
GOCARDLESS_ACCESS_TOKEN=your_live_or_sandbox_access_token
GOCARDLESS_ENVIRONMENT=sandbox
GOCARDLESS_WEBHOOK_SECRET=your_webhook_secret
# Webhook URL to register in GoCardless dashboard:
#   https://visitpro.de/api/v1/webhooks/gocardless
GOCARDLESS_SUCCESS_REDIRECT_URL=https://visitpro.de/settings?tab=billing&status=success

# ── First Super Admin (run init_db.py once, then protect these) ──
FIRST_SUPERADMIN_EMAIL=admin@visitpro.de
FIRST_SUPERADMIN_PASSWORD=change_me_immediately
